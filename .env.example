# API
PORT=8787
API_ORIGIN=http://localhost:8787
WEB_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-in-production

# Stripe — same account as mirrorpathai.com (run: pnpm stripe:setup)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PERSONAL=price_...
STRIPE_PRICE_PRO=price_...
# Mirror Path style Payment Links (optional; used if set)
STRIPE_PAYMENT_LINK_PERSONAL=https://buy.stripe.com/...
STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/...

# Database (Railway Postgres in production — enables persistent WWH2 feedback)
DATABASE_URL=postgres://user:pass@host:5432/secretlayer
# PGSSLMODE=disable

# WWH2 feedback fallback when DATABASE_URL is unset (local dev)
WWH2_DATA_DIR=./data

# Promotion (optional — used when checks pass)
NETLIFY_BUILD_HOOK=
PROMOTION_WEBHOOK_URL=
ADMIN_API_KEY=
SAFETY_SCORE=84
SAFETY_PASSED=true

# Web (optional local override)
VITE_API_URL=/api
