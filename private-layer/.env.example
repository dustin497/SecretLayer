# Local LLM (Ollama default)
OLLAMA_HOST=http://127.0.0.1:11434
DEFAULT_MODEL=dolphin-mistral:latest

# Vault paths (set after VeraCrypt mount on Windows, e.g. V:\)
VAULT_ROOT=V:\PrivateLayer
OBSIDIAN_VAULT=V:\PrivateLayer\vault
MODELS_DIR=V:\PrivateLayer\models
DOCUMENTS_DIR=V:\PrivateLayer\documents
TRAINING_DIR=V:\PrivateLayer\training

# Agent behavior — you control this, not us
AGENT_SYSTEM_PROMPT_FILE=./vault-templates/system-prompt.txt
REQUIRE_ACTION_APPROVAL=true
AUTO_EXECUTE_LOW_RISK=false

# Training
BASE_MODEL_FOR_FINETUNE=Qwen/Qwen2.5-7B-Instruct
LORA_OUTPUT_DIR=./training-output
